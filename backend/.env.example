# Base de datos PostgreSQL (Neon Free Tier)
# Formato: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host/marketplace?sslmode=require"

# Secreto para firmar JWT (usa una cadena larga y aleatoria en producción)
JWT_SECRET="cambia_esto_por_un_secreto_seguro"

# Tiempo de expiración del token (ej: 7d, 24h, 60m)
JWT_EXPIRES_IN="7d"

# Puerto del servidor (Render lo asigna automáticamente via la variable PORT)
PORT=4000

# Entorno de ejecución
NODE_ENV="development"
